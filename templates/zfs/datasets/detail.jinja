<script>
// Parse human-readable size string (e.g., "160G", "1T", "48.7M") to bytes
function parseSizeToBytes(sizeStr) {
    if (!sizeStr) return 0;
    sizeStr = sizeStr.trim().toUpperCase();
    if (sizeStr === 'NONE' || sizeStr === '0' || sizeStr === '-' || sizeStr === '0B') return 0;
    var multipliers = { 'K': 1024, 'M': 1024*1024, 'G': 1024*1024*1024, 'T': 1024*1024*1024*1024, 'P': 1024*1024*1024*1024*1024 };
    var match = sizeStr.match(/^([0-9]*\.?[0-9]+)\s*([KMGTP]?)B?$/);
    if (!match) return -1;
    var num = parseFloat(match[1]);
    var suffix = match[2];
    if (suffix && multipliers[suffix]) {
        return num * multipliers[suffix];
    }
    return num;
}

// Format bytes to human-readable
function formatBytes(bytes) {
    if (bytes <= 0) return '0B';
    var units = ['B', 'K', 'M', 'G', 'T', 'P'];
    var i = 0;
    while (bytes >= 1024 && i < units.length - 1) { bytes /= 1024; i++; }
    return (i === 0 ? bytes : bytes.toFixed(1)) + units[i];
}

// Validate quota input against used/available space
function validateQuota() {
    var input = document.getElementById('quota_size');
    var msgDiv = document.getElementById('quota-validation');
    var submitBtn = document.getElementById('quota-submit');
    var form = document.getElementById('quota-form');
    var value = input.value.trim();

    if (!value || value.toLowerCase() === 'none') {
        msgDiv.classList.add('hidden');
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        return;
    }

    var usedStr = form.dataset.used || '0';
    var availStr = form.dataset.avail || '0';
    var usedBytes = parseSizeToBytes(usedStr);
    var availBytes = parseSizeToBytes(availStr);
    var maxBytes = usedBytes + availBytes;
    var inputBytes = parseSizeToBytes(value);

    if (inputBytes === -1) {
        msgDiv.textContent = 'Invalid format. Use a number with suffix: K, M, G, T (e.g., 200G, 1T)';
        msgDiv.className = 'text-xs text-warning-400';
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        return;
    }

    if (usedBytes > 0 && inputBytes < usedBytes) {
        msgDiv.textContent = 'Too small: must be at least ' + usedStr + ' (current used space)';
        msgDiv.className = 'text-xs text-danger-400';
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        return;
    }

    if (maxBytes > 0 && inputBytes > maxBytes) {
        msgDiv.textContent = 'Too large: maximum is ' + formatBytes(maxBytes) + ' (used + available)';
        msgDiv.className = 'text-xs text-danger-400';
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
        return;
    }

    msgDiv.textContent = 'Valid: ' + formatBytes(inputBytes);
    msgDiv.className = 'text-xs text-success-400';
    submitBtn.disabled = false;
    submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
}

// Ensure showConfirm function is available
window.showConfirm = function(dialogId) {
    const dialog = document.getElementById(dialogId);
    
    if (!dialog) {
        console.error('Dialog not found:', dialogId);
        return;
    }
    
    // Try using Alpine's global Alpine object if available
    if (window.Alpine) {
        // Use Alpine.$data to access the component's data
        const component = window.Alpine.$data(dialog);
        if (component) {
            component.open = true;
            return;
        }
    }
    
    // Fallback to __x property
    if (dialog.__x) {
        dialog.__x.$data.open = true;
        return;
    }
    
    // If neither works, try dispatching an event
    dialog.dispatchEvent(new CustomEvent('open-modal'));
    console.warn('Could not open modal using Alpine.js, tried dispatching event');
};
</script>
