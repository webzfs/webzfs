{% extends "layout_main.jinja" %}

{% block title %}{{ page_title }}{% endblock %}

{% block content %}
<div class="container-page">
    <!-- Breadcrumb -->
    <nav class="text-sm mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center space-x-2">
            <li class="flex items-center">
                <a href="/" class="text-primary-400 hover:text-primary-300 transition-colors">Home</a>
                <svg class="w-4 h-4 mx-2 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
            </li>
            <li>
                <span class="text-text-primary font-medium">ZFS Observability</span>
            </li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
        <div>
            <h1 class="text-3xl font-bold text-text-primary mb-2">ZFS Observability Dashboard</h1>
            <p class="text-text-secondary">Logs, events, performance metrics, and live ZFS monitoring</p>
        </div>
        <a href="/zfs/observability/download-all"
           class="btn-primary flex items-center gap-2"
           hx-boost="false">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
            </svg>
            <span class="font-semibold">Download All Logs (ZIP)</span>
        </a>
    </div>

    <!-- Error Message -->
    {% if error %}
    <div class="bg-danger-900/30 border-l-4 border-danger-500 text-danger-400 px-4 py-3 rounded mb-6" role="alert">
        <div class="flex items-start">
            <svg class="w-5 h-5 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
                <strong class="font-semibold">Error:</strong> {{ error }}
            </div>
        </div>
    </div>
    {% endif %}

    <!-- Quick Access Cards: Logs / Events / ARC / Search -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <a href="/zfs/observability/pool-history" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-primary-500/10 rounded-lg p-3 border border-primary-500/20">
                        <svg class="h-6 w-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">Pool History</p>
                        <p class="text-lg font-semibold text-text-primary">View Commands</p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/pool-events" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-warning-500/10 rounded-lg p-3 border border-warning-500/20">
                        <svg class="h-6 w-6 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">Pool Events</p>
                        <p class="text-lg font-semibold text-text-primary">View Events</p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/arc-summary" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-success-500/10 rounded-lg p-3 border border-success-500/20">
                        <svg class="h-6 w-6 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">ARC Hit Rate</p>
                        <p class="text-2xl font-semibold text-text-primary">
                            {% if arc_summary.get('hit_rate') %}
                                {{ "%.1f"|format(arc_summary.hit_rate) }}%
                            {% else %}
                                N/A
                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/search" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-purple-500/10 rounded-lg p-3 border border-purple-500/20">
                        <svg class="h-6 w-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">Search Logs</p>
                        <p class="text-lg font-semibold text-text-primary">All Sources</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Live Performance Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <a href="/zfs/observability/pool-iostat" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-primary-500/20 border border-primary-500/30 rounded-lg p-3">
                        <svg class="h-6 w-6 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 8 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">Pool I/O Stats</p>
                        <p class="text-lg font-semibold text-text-primary">Live Monitor</p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/arc-realtime" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-success-500/20 border border-success-500/30 rounded-lg p-3">
                        <svg class="h-6 w-6 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">ARC Real-Time</p>
                        <p class="text-lg font-semibold text-text-primary" id="arc-hit-rate-display">
                            {% if arc_summary.get('hit_rate') %}
                                {{ "%.1f"|format(arc_summary.hit_rate) }}%
                            {% else %}
                                Live View
                            {% endif %}
                        </p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/processes" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-purple-500/20 border border-purple-500/30 rounded-lg p-3">
                        <svg class="h-6 w-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">ZFS Processes</p>
                        <p class="text-lg font-semibold text-text-primary" id="process-count">{{ all_processes|length if all_processes else 'View' }}</p>
                    </div>
                </div>
            </div>
        </a>

        <a href="/zfs/observability/vdev-stats" class="card hover:shadow-xl transition-all duration-200 hover:-translate-y-1">
            <div class="card-body">
                <div class="flex items-center">
                    <div class="flex-shrink-0 bg-info-500/20 border border-info-500/30 rounded-lg p-3">
                        <svg class="h-6 w-6 text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                        </svg>
                    </div>
                    <div class="ml-4">
                        <p class="text-sm font-medium text-text-secondary">Per-VDEV Stats</p>
                        <p class="text-lg font-semibold text-text-primary">Live Monitor</p>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <!-- Recent Pool History (loaded via HTMX for performance) -->
    <div class="card mb-8">
        <div class="px-6 py-4 border-b border-border-subtle">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    Recent Pool History
                </h2>
                <a href="/zfs/observability/pool-history" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors flex items-center gap-1">
                    View All
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto"
                 hx-get="/zfs/observability/recent-history-partial"
                 hx-trigger="load"
                 hx-swap="innerHTML">
                <div class="flex items-center justify-center py-8">
                    <svg class="animate-spin h-8 w-8 text-primary-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span class="ml-3 text-text-secondary">Loading history...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Pool Events (loaded via HTMX for performance) -->
    <div class="card mb-8">
        <div class="px-6 py-4 border-b border-border-subtle">
            <div class="flex justify-between items-center">
                <h2 class="text-xl font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                    </svg>
                    Recent Pool Events
                </h2>
                <a href="/zfs/observability/pool-events" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors flex items-center gap-1">
                    View All
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        </div>
        <div class="p-6">
            <div class="overflow-x-auto"
                 hx-get="/zfs/observability/recent-events-partial"
                 hx-trigger="load"
                 hx-swap="innerHTML">
                <div class="flex items-center justify-center py-8">
                    <svg class="animate-spin h-8 w-8 text-warning-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span class="ml-3 text-text-secondary">Loading events...</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ZFS Processes (Active >1% CPU) -->
    <div class="card mb-8">
        <div class="card-body border-b border-border-subtle">
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-2">
                    <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                    </svg>
                    <h2 class="text-xl font-semibold text-text-primary">Active ZFS Processes</h2>
                    <span class="text-xs text-text-tertiary italic">(showing processes >1% CPU)</span>
                </div>
                <a href="/zfs/observability/processes" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors">
                    View All
                    <svg class="w-4 h-4 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                </a>
            </div>
        </div>
        <div class="card-body">
            {% if processes %}
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-border-subtle">
                    <thead class="bg-bg-elevated-2">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">PID</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Name</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">User</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">CPU %</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Memory %</th>
                            <th class="px-4 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-border-subtle" id="processes-tbody">
                        {% for proc in processes %}
                        <tr class="hover:bg-bg-elevated-2 transition-colors">
                            <td class="px-4 py-3 text-sm text-text-primary">{{ proc.pid }}</td>
                            <td class="px-4 py-3 text-sm font-medium text-text-primary">{{ proc.name }}</td>
                            <td class="px-4 py-3 text-sm text-text-secondary">{{ proc.username }}</td>
                            <td class="px-4 py-3 text-sm text-text-primary">{{ "%.1f"|format(proc.cpu_percent) }}%</td>
                            <td class="px-4 py-3 text-sm text-text-primary">{{ "%.1f"|format(proc.memory_percent) }}%</td>
                            <td class="px-4 py-3 text-sm">
                                <span class="badge
                                    {% if proc.status == 'running' %}
                                        badge-success
                                    {% elif proc.status == 'sleeping' %}
                                        badge-info
                                    {% else %}
                                        badge-secondary
                                    {% endif %}">
                                    {{ proc.status }}
                                </span>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div class="text-center py-8">
                <svg class="mx-auto h-12 w-12 text-text-tertiary mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                </svg>
                <p class="text-text-secondary">No ZFS processes using more than 1% CPU</p>
                <p class="text-text-tertiary text-sm mt-2">
                    <a href="/zfs/observability/processes" class="text-primary-400 hover:text-primary-300">View all processes</a>
                </p>
            </div>
            {% endif %}
        </div>
    </div>

    <!-- Additional Resources Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- More Log Sources -->
        <div class="card">
            <div class="px-6 py-4 border-b border-border-subtle">
                <h3 class="text-lg font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                    More Log Sources
                </h3>
            </div>
            <div class="p-6">
                <ul class="space-y-3">
                    <li>
                        <a href="/zfs/observability/kernel-log" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            Kernel Debug Log
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/syslog" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            System Log (ZFS filtered)
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/syslog-full" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            System Log (Full)
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/module-parameters" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            Module Parameters
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Additional Performance Monitoring -->
        <div class="card">
            <div class="px-6 py-4 border-b border-border-subtle">
                <h3 class="text-lg font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                    Performance Tools
                </h3>
            </div>
            <div class="p-6">
                <ul class="space-y-3">
                    <li>
                        <a href="/zfs/observability/pool-iostat" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            Pool I/O Statistics
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/vdev-stats" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            Per-VDEV Statistics
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/dataset-space" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            Dataset Space Usage
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/system-iostat" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            System I/O Statistics
                        </a>
                    </li>
                    <li>
                        <a href="/zfs/observability/processes" class="flex items-center text-primary-400 hover:text-primary-300 transition-colors group">
                            <svg class="w-4 h-4 mr-2 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            ZFS Processes
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- ARC Statistics -->
        <div class="card">
            <div class="px-6 py-4 border-b border-border-subtle">
                <h3 class="text-lg font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                    </svg>
                    ARC Statistics
                </h3>
            </div>
            <div class="p-6">
                {% if arc_summary and arc_summary.get('size_human') and not arc_summary.get('error') %}
                <dl class="space-y-3">
                    <div class="flex justify-between items-center py-2 border-b border-border-subtle">
                        <dt class="text-text-secondary">Current Size:</dt>
                        <dd class="font-semibold text-text-primary">{{ arc_summary.size_human }}</dd>
                    </div>
                    <div class="flex justify-between items-center py-2 border-b border-border-subtle">
                        <dt class="text-text-secondary">Max Size:</dt>
                        <dd class="font-semibold text-text-primary">{{ arc_summary.c_max_human }}</dd>
                    </div>
                    {% if arc_summary.get('hit_rate') is not none %}
                    <div class="flex justify-between items-center py-2">
                        <dt class="text-text-secondary">Hit Rate:</dt>
                        <dd class="font-semibold {% if arc_summary.hit_rate >= 80 %}text-success-400{% elif arc_summary.hit_rate >= 60 %}text-warning-400{% else %}text-danger-400{% endif %}">
                            {{ "%.2f"|format(arc_summary.hit_rate) }}%
                        </dd>
                    </div>
                    {% endif %}
                </dl>
                <div class="mt-4 space-y-2">
                    <a href="/zfs/observability/arc-summary" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors flex items-center gap-1">
                        Detailed ARC Summary
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                    <a href="/zfs/observability/arc-realtime" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors flex items-center gap-1">
                        Real-Time ARC Monitor
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
                {% else %}
                <div class="text-center py-4">
                    <svg class="w-12 h-12 mx-auto text-text-tertiary mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                    </svg>
                    <p class="text-text-secondary text-sm">
                        {% if arc_summary.get('error') %}
                            Error: {{ arc_summary.error }}
                        {% else %}
                            ARC statistics not available
                        {% endif %}
                    </p>
                </div>
                <div class="mt-4">
                    <a href="/zfs/observability/arc-summary" class="text-primary-400 hover:text-primary-300 text-sm font-medium transition-colors flex items-center gap-1">
                        View ARC Page
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                        </svg>
                    </a>
                </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script>
    // Auto-refresh active processes table every 5 seconds
    let autoRefreshActiveProcesses = true;
    let refreshTimer;

    async function refreshActiveProcesses() {
        try {
            const response = await fetch('/zfs/observability/api/processes');
            if (!response.ok) return;
            const data = await response.json();
            const allProcesses = data.processes || [];
            const activeProcesses = allProcesses.filter(p => p.cpu_percent > 1.0);

            const countEl = document.getElementById('process-count');
            if (countEl) countEl.textContent = allProcesses.length;

            const tbody = document.getElementById('processes-tbody');
            if (!tbody) return;

            if (activeProcesses.length > 0) {
                tbody.innerHTML = activeProcesses.map(proc => {
                    let statusBadge = 'badge-secondary';
                    if (proc.status === 'running') statusBadge = 'badge-success';
                    else if (proc.status === 'sleeping') statusBadge = 'badge-info';

                    return `
                    <tr class="hover:bg-bg-elevated-2 transition-colors">
                        <td class="px-4 py-3 text-sm text-text-primary">${proc.pid}</td>
                        <td class="px-4 py-3 text-sm font-medium text-text-primary">${proc.name}</td>
                        <td class="px-4 py-3 text-sm text-text-secondary">${proc.username}</td>
                        <td class="px-4 py-3 text-sm text-text-primary">${proc.cpu_percent.toFixed(1)}%</td>
                        <td class="px-4 py-3 text-sm text-text-primary">${proc.memory_percent.toFixed(1)}%</td>
                        <td class="px-4 py-3 text-sm">
                            <span class="badge ${statusBadge}">${proc.status}</span>
                        </td>
                    </tr>`;
                }).join('');
            }

            // Refresh ARC hit rate display
            const arcResponse = await fetch('/zfs/observability/api/arc-stats');
            if (arcResponse.ok) {
                const arcData = await arcResponse.json();
                const arcEl = document.getElementById('arc-hit-rate-display');
                if (arcEl && arcData.hit_rate !== undefined && arcData.hit_rate !== null) {
                    arcEl.textContent = arcData.hit_rate.toFixed(1) + '%';
                }
            }
        } catch (err) {
            console.error('Error refreshing observability stats:', err);
        }
    }

    function startRefreshTimer() {
        if (refreshTimer) clearInterval(refreshTimer);
        refreshTimer = setInterval(refreshActiveProcesses, 5000);
    }

    if (autoRefreshActiveProcesses) startRefreshTimer();

    // Pause when tab is hidden
    document.addEventListener('visibilitychange', () => {
        if (document.hidden) {
            if (refreshTimer) clearInterval(refreshTimer);
        } else if (autoRefreshActiveProcesses) {
            startRefreshTimer();
        }
    });

    window.addEventListener('beforeunload', () => {
        if (refreshTimer) clearInterval(refreshTimer);
    });
</script>
{% endblock %}
