function isAckValid() {
    try {
        var stored = sessionStorage.getItem(ACK_STORAGE_KEY);
        if (!stored) return false;
        var ackTime = parseInt(stored, 10);
        if (isNaN(ackTime)) return false;
        return (Date.now() - ackTime) < ACK_TIMEOUT_MS;
    } catch (e) {
        return false;
    }
}

