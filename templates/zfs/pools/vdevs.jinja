function formatBytesHuman(bytes) {
    if (!bytes || bytes <= 0) return '';
    var units = ['B', 'KB', 'MB', 'GB', 'TB', 'PB'];
    var i = 0;
    var val = bytes;
    while (val >= 1024 && i < units.length - 1) { val /= 1024; i++; }
    if (i <= 1) return Math.round(val) + ' ' + units[i];
    return val.toFixed(1) + ' ' + units[i];
}

