// ==================== Operation Card Gating ====================
// Cards are locked until disk check is completed
function lockOperationCards() {
    if (disksChecked) return;
    var cardIds = ['card-attach', 'card-replace', 'card-add-aux'];
    cardIds.forEach(function(id) {
        var card = document.getElementById(id);
        if (!card) return;
        // Only lock if not already disabled by pool type constraints
        if (card.style.opacity === '0.4') return;
        card.style.position = 'relative';
        // Add overlay
        var overlay = document.createElement('div');
        overlay.id = id + '-lock-overlay';
        overlay.className = 'absolute inset-0 bg-bg-base/70 backdrop-blur-[3px] z-30 rounded-xl flex items-center justify-center cursor-not-allowed';
        overlay.innerHTML = '<div class="text-center p-6"><svg class="w-12 h-12 mx-auto text-info-400 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg><p class="text-info-400 text-sm font-semibold">Run "Detect Disks in Use" first</p></div>';
        card.appendChild(overlay);
    });
}

function unlockOperationCards() {
    disksChecked = true;
    var cardIds = ['card-attach', 'card-replace', 'card-add-aux'];
    cardIds.forEach(function(id) {
        var overlay = document.getElementById(id + '-lock-overlay');
        if (overlay) overlay.remove();
    });
    // Re-apply pool type constraints (attach may still be disabled for raidz)
    if (pageData && pageData.topology) {
        // Attach constraint is already applied; nothing extra needed here
    }
}

// ==================== Pool Type Constraints ====================
function applyPoolTypeConstraints(topology) {
    // Determine the primary data vdev type from the pool topology
    var dataVdevs = topology.data_vdevs || [];
    var poolDataType = null;
    var hasMirrorOrSingle = false;
    var hasRaidz = false;

    dataVdevs.forEach(function(vdev) {
        var vtype = (vdev.type || '').toLowerCase();
        if (vtype === 'mirror' || vtype === 'single' || vtype === '') {
            hasMirrorOrSingle = true;
            if (!poolDataType) poolDataType = vtype || 'single';
        } else if (vtype.indexOf('raidz') === 0) {
            hasRaidz = true;
            if (!poolDataType) poolDataType = vtype;
        }
    });

    // Check if pool has any mirror vdevs
    var hasMirror = false;
    dataVdevs.forEach(function(vdev) {
        if ((vdev.type || '').toLowerCase() === 'mirror') hasMirror = true;
    });

    // 1. Grey out "Attach Device (Mirror)" card if pool uses raidz vdevs
    //    Attach only works for single/mirror vdevs
    var attachCard = document.getElementById('form-attach');
    if (attachCard) {
        var attachCardParent = attachCard.closest('.card');
        if (hasRaidz && !hasMirrorOrSingle) {
            // All data vdevs are raidz - disable attach
            attachCardParent.style.opacity = '0.4';
            attachCardParent.style.pointerEvents = 'none';
            // Add explanation banner
            var notice = document.createElement('div');
            notice.className = 'bg-bg-elevated rounded-lg border border-border-subtle p-3 text-xs text-text-tertiary mb-4';
            notice.innerHTML = '<strong class="text-text-secondary">Not available:</strong> This pool uses RAIDZ vdevs. Attach (mirror) is only available for single-disk or mirror vdevs.';
            attachCard.parentElement.insertBefore(notice, attachCard);
        }
    }

    // 2. Grey out "Bring Device Online" section if no devices are offline
    var hasOfflineDevice = false;
    var allSections = ['data_vdevs', 'log_vdevs', 'cache_vdevs', 'spare_vdevs', 'special_vdevs', 'dedup_vdevs'];
    allSections.forEach(function(secKey) {
        var vdevs = topology[secKey] || [];
        vdevs.forEach(function(vdev) {
            (vdev.devices || []).forEach(function(dev) {
                if (dev.state === 'OFFLINE') hasOfflineDevice = true;
            });
        });
    });

    var onlineSection = document.getElementById('online-section');
    if (onlineSection && !hasOfflineDevice) {
        onlineSection.style.opacity = '0.4';
        onlineSection.style.pointerEvents = 'none';
        var onlineNotice = document.createElement('div');
        onlineNotice.className = 'bg-bg-elevated rounded-lg border border-border-subtle p-2 text-xs text-text-tertiary mb-2';
        onlineNotice.innerHTML = '<strong class="text-text-secondary">Not available:</strong> No devices are currently offline in this pool.';
        onlineSection.parentElement.insertBefore(onlineNotice, onlineSection);
    }

    // 3. Grey out "Detach from Mirror" section if pool has no mirror vdevs
    var detachSection = document.getElementById('detach-section');
    if (detachSection && !hasMirror) {
        detachSection.style.opacity = '0.4';
        detachSection.style.pointerEvents = 'none';
        // Add explanation notice
        var detachNotice = document.createElement('div');
        detachNotice.className = 'bg-bg-elevated rounded-lg border border-border-subtle p-2 text-xs text-text-tertiary mb-2';
        detachNotice.innerHTML = '<strong class="text-text-secondary">Not available:</strong> This pool has no mirror vdevs. Detach only applies to devices in a mirror.';
        detachSection.parentElement.insertBefore(detachNotice, detachSection);
    }

}

