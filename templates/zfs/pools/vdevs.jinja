    html += '</div></div>';
    container.innerHTML = html;

    // Show the form
    form.classList.remove('hidden');

    // Attach click handlers
    removable.forEach(function(item, idx) {
        var btnId = 'remove-aux-btn-' + idx;
        var btn = document.getElementById(btnId);
        if (btn) {
            btn.addEventListener('click', function() {
                document.getElementById('remove-device').value = item.name;
            });
        }
    });
}

function selectRemoveVdev(deviceName) {
    document.getElementById('remove-device').value = deviceName;
}

// ==================== Utility ====================
function escHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
function escAttr(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}

