<style>
.disk-btn { transition: all 0.15s ease; }
.disk-btn:hover { transform: translateY(-1px); }
.disk-btn-system { border-color: #dc2626 !important; background-color: rgba(153,27,27,0.4) !important; cursor: not-allowed !important; opacity: 0.6; }
.disk-btn-active { border-color: #f87171 !important; background-color: rgba(153,27,27,0.2) !important; cursor: not-allowed !important; opacity: 0.7; }
.disk-btn-labeled { border-color: #fbbf24 !important; background-color: rgba(120,53,15,0.2) !important; }
</style>

<script>
var pageData = null;
var poolName = '{{ pool_name }}';
var disksChecked = false;

// ==================== Modal Helper ====================
window.showConfirm = function(dialogId) {
    var dialog = document.getElementById(dialogId);
    if (!dialog) { console.error('Dialog not found:', dialogId); return; }
    if (window.Alpine) {
        var component = window.Alpine.$data(dialog);
        if (component) { component.open = true; return; }
    }
    if (dialog.__x) { dialog.__x.$data.open = true; return; }
    dialog.dispatchEvent(new CustomEvent('open-modal'));
};

// ==================== Async Page Load ====================
async function loadPageData() {
    document.getElementById('loading-state').classList.remove('hidden');
    document.getElementById('error-state').classList.add('hidden');
    document.getElementById('main-content').classList.add('hidden');

    try {
        var response = await fetch('/zfs/pools/' + poolName + '/vdevs/data');
        var data = await response.json();

        if (!data.success) {
            throw new Error(data.error || 'Unknown error');
        }

        pageData = data;
        renderTopology(data.topology);
        renderDiskButtons(data.all_disks, data.pool_devices);
        renderResilverBanner(data.topology);
        applyPoolTypeConstraints(data.topology);
        renderRemovableVdevs(data.topology);
        updateAuxLayoutOptions();

        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('main-content').classList.remove('hidden');

        // Lock operation cards until disk check is completed
        lockOperationCards();
    } catch (err) {
        document.getElementById('loading-state').classList.add('hidden');
        document.getElementById('error-state').classList.remove('hidden');
        document.getElementById('error-state-message').textContent = err.message || 'Failed to fetch data';
    }
}

// ==================== Resilver Banner ====================
function renderResilverBanner(topology) {
    var banner = document.getElementById('resilver-banner');
    var info = topology.scan_info || '';
    if (info.toLowerCase().indexOf('resilver') !== -1) {
        document.getElementById('resilver-info').textContent = info;
        banner.classList.remove('hidden');
    } else {
        banner.classList.add('hidden');
    }
}

// ==================== Topology Rendering ====================
function renderTopology(topology) {
    var container = document.getElementById('topology-container');
    var html = '';

    var sections = [
        { key: 'data_vdevs', label: 'Data VDevs', color: 'primary' },
        { key: 'log_vdevs', label: 'Log (SLOG) VDevs', color: 'info' },
        { key: 'cache_vdevs', label: 'Cache (L2ARC) VDevs', color: 'success' },
        { key: 'spare_vdevs', label: 'Hot Spares', color: 'warning' },
        { key: 'special_vdevs', label: 'Special VDevs', color: 'purple' },
        { key: 'dedup_vdevs', label: 'Dedup VDevs', color: 'indigo' }
    ];

    var hasAny = false;
    sections.forEach(function(sec) {
        var vdevs = topology[sec.key] || [];
        if (vdevs.length === 0) return;
        hasAny = true;

        html += '<div class="mb-6 last:mb-0">';
        html += '<h3 class="text-sm font-semibold text-' + sec.color + '-400 uppercase tracking-wider mb-3">' + sec.label + '</h3>';

        vdevs.forEach(function(vdev) {
            var typeBadge = '';
            if (vdev.type === 'mirror') {
                typeBadge = '<span class="px-2 py-0.5 rounded text-xs font-semibold bg-primary-900/50 text-primary-400 border border-primary-900">MIRROR</span>';
            } else if (vdev.type && vdev.type.indexOf('raidz') === 0) {
                typeBadge = '<span class="px-2 py-0.5 rounded text-xs font-semibold bg-purple-900/50 text-purple-400 border border-purple-900">' + vdev.type.toUpperCase() + '</span>';
            } else {
                typeBadge = '<span class="px-2 py-0.5 rounded text-xs font-semibold bg-bg-elevated-2 text-text-secondary border border-border-subtle">SINGLE</span>';
            }

            var stateBadge = stateHtml(vdev.state);

            html += '<div class="card-nested mb-3">';
            html += '<div class="flex items-center justify-between mb-2"><div class="flex items-center gap-2">' + typeBadge + '<span class="text-text-primary font-mono text-sm">' + escHtml(vdev.name) + '</span></div><div>' + stateBadge + '</div></div>';

            // Device table
            html += '<div class="overflow-x-auto"><table class="min-w-full text-sm"><thead><tr class="border-b border-border-subtle">';
            html += '<th class="text-left py-1.5 px-2 text-text-tertiary font-medium text-xs">Device</th>';
            html += '<th class="text-left py-1.5 px-2 text-text-tertiary font-medium text-xs">State</th>';
            html += '<th class="text-right py-1.5 px-2 text-text-tertiary font-medium text-xs">Read</th>';
            html += '<th class="text-right py-1.5 px-2 text-text-tertiary font-medium text-xs">Write</th>';
            html += '<th class="text-right py-1.5 px-2 text-text-tertiary font-medium text-xs">Cksum</th>';
            html += '<th class="text-right py-1.5 px-2 text-text-tertiary font-medium text-xs">Actions</th>';
            html += '</tr></thead><tbody>';

            (vdev.devices || []).forEach(function(dev) {
                var errClass = function(v) { return v > 0 ? 'text-danger-400' : 'text-text-tertiary'; };
                html += '<tr class="border-b border-border-subtle/30">';
                html += '<td class="py-1.5 px-2 font-mono text-text-primary text-xs">' + escHtml(dev.name);
                if (dev.notes) html += ' <span class="text-info-400">(' + escHtml(dev.notes) + ')</span>';
                html += '</td>';
                html += '<td class="py-1.5 px-2">' + stateHtml(dev.state) + '</td>';
                html += '<td class="py-1.5 px-2 text-right font-mono text-xs ' + errClass(dev.read_errors) + '">' + dev.read_errors + '</td>';
                html += '<td class="py-1.5 px-2 text-right font-mono text-xs ' + errClass(dev.write_errors) + '">' + dev.write_errors + '</td>';
                html += '<td class="py-1.5 px-2 text-right font-mono text-xs ' + errClass(dev.cksum_errors) + '">' + dev.cksum_errors + '</td>';
                html += '<td class="py-1.5 px-2 text-right"><div class="flex items-center justify-end gap-1">';

                // Action buttons
                if (dev.state === 'ONLINE') {
                    html += '<button type="button" class="text-text-tertiary hover:text-warning-400 transition-colors p-0.5" title="Take Offline" onclick="prepareDeviceAction(\'offline\', \'' + escAttr(dev.name) + '\')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"></path></svg></button>';
                } else if (dev.state === 'OFFLINE') {
                    html += '<button type="button" class="text-text-tertiary hover:text-success-400 transition-colors p-0.5" title="Bring Online" onclick="prepareDeviceAction(\'online\', \'' + escAttr(dev.name) + '\')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></button>';
                }
                html += '<button type="button" class="text-text-tertiary hover:text-info-400 transition-colors p-0.5" title="Replace Device" onclick="prepareReplace(\'' + escAttr(dev.name) + '\')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path></svg></button>';
                if (vdev.type === 'mirror') {
                    html += '<button type="button" class="text-text-tertiary hover:text-danger-400 transition-colors p-0.5" title="Detach from Mirror" onclick="prepareDetach(\'' + escAttr(dev.name) + '\')"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path></svg></button>';
                }
                html += '</div></td></tr>';
            });
            html += '</tbody></table></div>';

            // Quick attach link for single/mirror data vdevs
            if (sec.key === 'data' && (vdev.type === 'single' || vdev.type === 'mirror')) {
                var firstDev = (vdev.devices && vdev.devices.length > 0) ? vdev.devices[0].name : '';
                var attachLabel = vdev.type === 'single' ? 'Attach disk to create mirror' : 'Attach disk to extend mirror';
                html += '<div class="mt-2 pt-2 border-t border-border-subtle/30"><button type="button" class="text-xs text-primary-400 hover:text-primary-300 transition-colors inline-flex items-center gap-1" onclick="prepareAttach(\'' + escAttr(firstDev) + '\')"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path></svg>' + attachLabel + '</button></div>';
            }

            html += '</div>';
        });
        html += '</div>';
    });

    if (!hasAny) {
        html = '<p class="text-text-tertiary text-sm">No topology information available.</p>';
    }
    container.innerHTML = html;
}

function stateHtml(state) {
    if (state === 'ONLINE') return '<span class="text-success-400 text-xs font-medium">ONLINE</span>';
    if (state === 'DEGRADED') return '<span class="text-warning-400 text-xs font-semibold">DEGRADED</span>';
    if (state === 'FAULTED' || state === 'UNAVAIL' || state === 'REMOVED') return '<span class="text-danger-400 text-xs font-semibold">' + state + '</span>';
    if (state === 'OFFLINE') return '<span class="text-text-tertiary text-xs font-medium">OFFLINE</span>';
    return '<span class="text-text-tertiary text-xs">' + (state || '') + '</span>';
}

// ==================== Disk Button Rendering ====================
function renderDiskButtons(allDisks, poolDevices) {
    // Categorize disks
    var freeDisksList = [];
    var systemDisksList = [];
    var inUseDisksList = [];

    allDisks.forEach(function(disk) {
        if (disk.is_system_disk) {
            systemDisksList.push(disk);
        } else if (disk.in_use) {
            inUseDisksList.push(disk);
        } else {
            freeDisksList.push(disk);
        }
    });

    // Render the system disks summary area
    renderAvailableDisksSection(allDisks, freeDisksList, systemDisksList, inUseDisksList);

    // Render free disk buttons for Add VDev
    renderDiskButtonsInto('add-vdev-disks', freeDisksList, function(disk) {
        appendDevice('add-devices', disk.device_path);
    });

    // Render free disk buttons for Attach (new device)
    renderDiskButtonsInto('attach-free-disks', freeDisksList, function(disk) {
        document.getElementById('attach-new').value = disk.device_path;
    });

    // Render pool device buttons for Attach (existing device)
    renderPoolDeviceButtonsInto('attach-pool-devices', poolDevices, function(devName) {
        document.getElementById('attach-existing').value = devName;
    });

    // Render pool device buttons for Replace (old device)
    renderPoolDeviceButtonsInto('replace-pool-devices', poolDevices, function(devName) {
        document.getElementById('replace-old').value = devName;
    });

    // Render free disk buttons for Replace (new device)
    renderDiskButtonsInto('replace-free-disks', freeDisksList, function(disk) {
        document.getElementById('replace-new').value = disk.device_path;
    });
}

function renderAvailableDisksSection(allDisks, freeDisksList, systemDisksList, inUseDisksList) {
    var container = document.getElementById('available-disks-container');
    var html = '';

    // Free disks
    if (freeDisksList.length > 0) {
        html += '<div class="mb-4"><h3 class="text-sm font-semibold text-success-400 mb-1">Available (Unused) ZFS Disks (' + freeDisksList.length + ')</h3>';
        html += '<p class="text-xs text-warning-400 mb-2">These disks may be in use by another filesystem. Verify before use.</p>';
        html += '<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">';
