{% extends "layout.jinja" %}

{% block content %}
<div class="space-y-6">
    <!-- Breadcrumb -->
    <nav class="flex items-center text-sm text-text-secondary">
        <a href="/zfs/pools" class="hover:text-text-primary transition-colors">Pools</a>
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
        <a href="/zfs/pools/{{ pool_name }}" class="hover:text-text-primary transition-colors">{{ pool_name }}</a>
        <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
        </svg>
        <span class="text-text-primary font-medium">VDev Management</span>
    </nav>

    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h1 class="text-3xl font-bold text-text-primary">VDev Management</h1>
            <p class="text-text-secondary mt-1">Pool: <span class="font-semibold text-text-primary">{{ pool_name }}</span></p>
        </div>
        <a href="/zfs/pools/{{ pool_name }}" class="btn-secondary inline-flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Back to Pool
        </a>
    </div>

    <!-- Data Safety Warning Banner with Acknowledgment Gate -->
    <div id="vdev-warning-banner" class="bg-danger-900/20 border-2 border-danger-500 rounded-xl p-4">
        <div class="flex items-start gap-3">
            <svg class="w-6 h-6 text-danger-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
            </svg>
            <div class="flex-1">
                <h3 class="text-sm font-semibold text-danger-400 mb-1">Warning: Data Loss Risk</h3>
                <p class="text-xs text-text-secondary mb-3">Incorrect selection of disks or improper vdev operations may result in <strong class="text-danger-300">irreversible data corruption or loss</strong>. Double check all device names and operation parameters before confirming any changes. Ensure you have verified which disks are in use and have current backups before modifying pool topology.</p>
                <button type="button" id="btn-acknowledge"
                        class="btn-danger text-sm inline-flex items-center gap-2"
                        onclick="acknowledgeWarning()">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    I Understand the Risks -- Proceed
                </button>
            </div>
        </div>
    </div>

    <!-- Greyed out placeholder when not acknowledged -->
    <div id="vdev-locked-overlay" class="relative">
        <div class="absolute inset-0 bg-bg-base/70 backdrop-blur-[1px] z-40 rounded-xl cursor-not-allowed"></div>
        <div class="opacity-30 pointer-events-none select-none">
            <div class="card p-8 text-center">
                <svg class="w-16 h-16 mx-auto text-text-tertiary mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
                <p class="text-text-tertiary text-sm">Acknowledge the data safety warning above to access VDev management operations.</p>
            </div>
        </div>
    </div>

    <!-- All page content gated behind acknowledgment (hidden until acknowledged) -->
    <div id="vdev-page-content" style="display: none;">

    <!-- Success/Error Messages -->
    {% if request.query_params.get('message') %}
    <div class="alert-success animate-slide-in" role="alert">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <svg class="w-5 h-5 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="flex-1 ml-3">
                <div class="text-sm text-success-300">{{ request.query_params.get('message') }}</div>
            </div>
            <button type="button" class="flex-shrink-0 ml-4 inline-flex text-success-400 hover:text-success-300 p-1.5 rounded-lg" onclick="this.closest('.alert-success').remove()">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </div>
    </div>
    {% endif %}
    {% if request.query_params.get('error') %}
    <div class="alert-danger animate-slide-in" role="alert">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <svg class="w-5 h-5 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                </svg>
            </div>
            <div class="flex-1 ml-3">
                <pre class="whitespace-pre-wrap font-mono text-xs text-danger-300">{{ request.query_params.get('error') }}</pre>
            </div>
            <button type="button" class="flex-shrink-0 ml-4 inline-flex text-danger-400 hover:text-danger-300 p-1.5 rounded-lg" onclick="this.closest('.alert-danger').remove()">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/></svg>
            </button>
        </div>
    </div>
    {% endif %}

    <!-- Loading State -->
    <div id="loading-state" class="card">
        <div class="flex items-center justify-center py-12">
            <div class="flex flex-col items-center gap-4">
                <div class="loading-spinner loading-spinner-lg"></div>
                <p class="text-text-secondary text-sm">Loading pool topology and disk information...</p>
                <p class="text-text-tertiary text-xs">This may take a moment on systems with many drives.</p>
            </div>
        </div>
    </div>

    <!-- Error State (hidden by default) -->
    <div id="error-state" class="card hidden">
        <div class="flex items-center justify-center py-12">
            <div class="flex flex-col items-center gap-4 text-center">
                <svg class="w-12 h-12 text-danger-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <p class="text-text-primary font-semibold">Failed to load data</p>
                <p id="error-state-message" class="text-text-secondary text-sm"></p>
                <button type="button" onclick="loadPageData()" class="btn-primary">Retry</button>
            </div>
        </div>
    </div>

    <!-- Main Content (hidden until data loads) -->
    <div id="main-content" class="space-y-6 hidden">

        <!-- Resilvering Status Banner -->
        <div id="resilver-banner" class="card bg-info-900/20 border border-info-700/50 hidden">
            <div class="flex items-start gap-3">
                <svg class="w-6 h-6 text-info-400 flex-shrink-0 mt-0.5 animate-pulse" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                <div>
                    <h3 class="text-info-400 font-semibold">Resilver In Progress</h3>
                    <p id="resilver-info" class="text-text-secondary text-sm mt-1"></p>
                </div>
            </div>
        </div>

        <!-- Pool Topology -->
        <div class="card">
            <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
                <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                </svg>
                Pool Topology
            </h2>
            <div id="topology-container">
                <p class="text-text-tertiary text-sm">No topology information available.</p>
            </div>
        </div>

        <!-- Disk Status Legend + Detect Button -->
        <div class="card">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-lg font-semibold text-text-primary flex items-center gap-2">
                    <svg class="w-5 h-5 text-text-tertiary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"></path>
                    </svg>
                    System Disks
                </h2>
                <div class="flex flex-col items-end gap-1">
                    <button type="button"
                            onclick="showConfirm('confirm-check-disks')"
                            class="btn-warning text-sm py-2 px-3 inline-flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        Detect Disks in Use
                    </button>
                    <span class="text-xs text-text-tertiary italic">(Linux Only)</span>
                </div>
            </div>

            <!-- Disk Status Legend -->
            <div class="p-3 bg-bg-elevated rounded-lg border border-border-subtle mb-4">
                <h3 class="text-xs font-semibold text-text-primary mb-2 uppercase tracking-wider">Disk Status</h3>
                <div class="space-y-2 text-xs">
                    <div class="flex items-center gap-2">
                        <div class="w-5 h-5 rounded border-2 flex-shrink-0" style="border-color: #dc2626; background-color: rgba(153, 27, 27, 0.5);"></div>
                        <span class="text-text-secondary"><strong>OS/System Disk</strong> -- CANNOT be used (contains OS/swap)</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-5 h-5 rounded border-2 flex-shrink-0" style="border-color: #f87171; background-color: rgba(153, 27, 27, 0.3);"></div>
                        <span class="text-text-secondary">In Active Pool -- Cannot be used for add/attach</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-5 h-5 rounded border-2 flex-shrink-0" style="border-color: #fbbf24; background-color: rgba(120, 53, 15, 0.3);"></div>
                        <span class="text-text-secondary">Has ZFS Label -- Use with caution</span>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="w-5 h-5 rounded border-2 flex-shrink-0 bg-success-900/30" style="border-color: #4ade80;"></div>
                        <span class="text-text-secondary">Available -- Free to use</span>
                    </div>
                </div>
            </div>

            <!-- Available Disks (populated by JS) -->
            <div id="available-disks-container">
                <p class="text-text-tertiary text-sm text-center py-4">Disk data will load with page data.</p>
            </div>
        </div>

        <!-- Operations Section -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- Attach Device (Create/Extend Mirror) -->
            <div id="card-attach" class="card">
                <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
                    </svg>
                    Attach Device (Mirror)
                </h2>
                <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/attach" id="form-attach">
                    <div class="space-y-3">
                        <div>
                            <label for="attach-existing" class="form-label">Existing Device in Pool</label>
                            <input type="text" id="attach-existing" name="existing_device" required
                                   placeholder="e.g., /dev/sda or sda"
                                   class="form-input w-full">
                            <p class="text-xs text-text-tertiary mt-1">The device already in the pool to mirror with</p>
                        </div>
                        <div>
                            <label class="form-label">Pool Devices</label>
                            <div id="attach-pool-devices" class="flex flex-wrap gap-1.5">
                                <span class="text-xs text-text-tertiary">Loading...</span>
                            </div>
                        </div>
                        <div>
                            <label for="attach-new" class="form-label">New Device to Attach</label>
                            <input type="text" id="attach-new" name="new_device" required
                                   placeholder="e.g., /dev/sdb"
                                   class="form-input w-full">
                        </div>
                        <div>
                            <label class="form-label">Available (Unused) ZFS Disks</label>
                            <p class="text-xs text-warning-400 mb-1">These disks may be in use by another filesystem. Verify before use.</p>
                            <div id="attach-free-disks" class="flex flex-wrap gap-1.5">
                                <span class="text-xs text-text-tertiary">Loading...</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="attach-force" name="force" value="true"
                                   class="rounded border-border-subtle bg-bg-elevated-2 text-primary-500 focus:ring-primary-500">
                            <label for="attach-force" class="text-sm text-text-secondary">Force</label>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="button" class="btn-primary inline-flex items-center gap-2"
                                onclick="showConfirm('confirm-attach')">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101"></path>
                            </svg>
                            Attach Device
                        </button>
                    </div>
                </form>
            </div>

            <!-- Replace Device -->
            <div id="card-replace" class="card">
                <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                    </svg>
                    Replace Device
                </h2>
                <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/replace" id="form-replace">
                    <div class="space-y-3">
                        <div>
                            <label for="replace-old" class="form-label">Device to Replace (in pool)</label>
                            <input type="text" id="replace-old" name="old_device" required
                                   placeholder="e.g., /dev/sda or sda"
                                   class="form-input w-full">
                        </div>
                        <div>
                            <label class="form-label">Pool Devices</label>
                            <div id="replace-pool-devices" class="flex flex-wrap gap-1.5">
                                <span class="text-xs text-text-tertiary">Loading...</span>
                            </div>
                        </div>
                        <div>
                            <label for="replace-new" class="form-label">Replacement Device (unused)</label>
                            <input type="text" id="replace-new" name="new_device" required
                                   placeholder="e.g., /dev/sdb"
                                   class="form-input w-full">
                        </div>
                        <div>
                            <label class="form-label">Available (Unused) ZFS Disks</label>
                            <p class="text-xs text-warning-400 mb-1">These disks may be in use by another filesystem. Verify before use.</p>
                            <div id="replace-free-disks" class="flex flex-wrap gap-1.5">
                                <span class="text-xs text-text-tertiary">Loading...</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2">
                            <input type="checkbox" id="replace-force" name="force" value="true"
                                   class="rounded border-border-subtle bg-bg-elevated-2 text-primary-500 focus:ring-primary-500">
                            <label for="replace-force" class="text-sm text-text-secondary">Force</label>
                        </div>
                    </div>
                    <div class="mt-4">
                        <button type="button" class="btn-info inline-flex items-center gap-2"
                                onclick="showConfirm('confirm-replace')">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"></path>
                            </svg>
                            Replace Device
                        </button>
                    </div>
                </form>
            </div>

            <!-- Detach / Remove / Online / Offline -->
            <div class="card">
                <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                    Device Operations
                </h2>
                <div class="space-y-4">
                    <!-- Detach -->
                    <div class="card-nested" id="detach-section">
                        <h3 class="text-sm font-semibold text-text-primary mb-2">Detach from Mirror</h3>
                        <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/detach" id="form-detach">
                            <div class="flex flex-col sm:flex-row gap-2">
                                <input type="text" id="detach-device" name="device" required
                                       placeholder="Device to detach"
                                       class="form-input flex-1">
                                <button type="button" class="btn-danger inline-flex items-center gap-2"
                                        onclick="showConfirm('confirm-detach')">
                                    Detach
                                </button>
                            </div>
                            <p class="text-xs text-text-tertiary mt-1">Only works for devices in a mirror vdev.</p>
                        </form>
                    </div>

                    <!-- Online -->
                    <div class="card-nested" id="online-section">
                        <h3 class="text-sm font-semibold text-text-primary mb-2">Bring Device Online</h3>
                        <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/online" id="form-online">
                            <div class="flex flex-col sm:flex-row gap-2 items-end">
                                <div class="flex-1 w-full">
                                    <input type="text" id="online-device" name="device" required
                                           placeholder="Device to bring online"
                                           class="form-input w-full">
                                </div>
                                <button type="button" class="btn-success inline-flex items-center gap-2"
                                        onclick="showConfirm('confirm-online')">
                                    Online
                                </button>
                            </div>
                        </form>
                    </div>

                    <!-- Offline -->
                    <div class="card-nested">
                        <h3 class="text-sm font-semibold text-text-primary mb-2">Take Device Offline</h3>
                        <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/offline" id="form-offline">
                            <div class="flex flex-col sm:flex-row gap-2 items-end">
                                <div class="flex-1 w-full">
                                    <input type="text" id="offline-device" name="device" required
                                           placeholder="Device to take offline"
                                           class="form-input w-full">
                                </div>
                                <div class="flex items-center gap-2">
                                    <input type="checkbox" id="offline-temp" name="temporary" value="true"
                                           class="rounded border-border-subtle bg-bg-elevated-2 text-primary-500 focus:ring-primary-500">
                                    <label for="offline-temp" class="text-sm text-text-secondary whitespace-nowrap">Temporary</label>
                                </div>
                                <button type="button" class="btn-warning inline-flex items-center gap-2"
                                        onclick="showConfirm('confirm-offline')">
                                    Offline
                                </button>
                            </div>
                            <p class="text-xs text-text-tertiary mt-1">Temporary: device will auto-online on reboot.</p>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Auxiliary VDev Management -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">

            <!-- Add Auxiliary VDev -->
            <div id="card-add-aux" class="card">
                <h2 class="text-lg font-semibold text-text-primary mb-4 flex items-center gap-2">
                    <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Auxiliary VDev
                </h2>
                <form method="post" action="/zfs/pools/{{ pool_name }}/vdevs/add" id="form-add-vdev">
                    <div class="space-y-3">
                        <div>
                            <label for="add-vdev-type" class="form-label">VDev Type</label>
                            <select id="add-vdev-type" name="vdev_type" class="form-input w-full" onchange="updateAuxLayoutOptions()">
                                <optgroup label="Removable (can be added and removed)">
                                    <option value="spare">Hot Spare</option>
                                    <option value="cache">Cache (L2ARC)</option>
                                    <option value="log">Log (SLOG)</option>
                                </optgroup>
                                <optgroup label="Permanent (cannot be removed once added)">
                                    <option value="special">Special Metadata VDev</option>
                                    <option value="dedup">Dedup VDev</option>
                                </optgroup>
                            </select>
                        </div>
                        <div id="aux-layout-section">
                            <label for="add-vdev-layout" class="form-label">Layout</label>
                            <select id="add-vdev-layout" name="vdev_layout" class="form-input w-full">
