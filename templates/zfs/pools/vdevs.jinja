// ==================== Disk-in-Use Check ====================
async function runDiskCheck() {
    // Get the modal's Alpine component to control state
    var modalEl = document.getElementById('confirm-check-disks');
    var modalData = null;
    if (window.Alpine) {
        modalData = window.Alpine.$data(modalEl);
    } else if (modalEl.__x) {
        modalData = modalEl.__x.$data;
    }

    try {
        var response = await fetch('/zfs/pools/' + poolName + '/vdevs/check-disk-usage');
        var data = await response.json();

        if (data.success && data.disk_status && pageData) {
            // Update disk statuses in our cached page data
            pageData.all_disks.forEach(function(disk) {
                var status = data.disk_status[disk.device_path];
                if (status) {
                    if (status.in_active_pool) {
                        disk.in_use = true;
                        disk.status_detail = 'active';
                        disk.pool_name = status.pool_name;
                    } else if (status.has_zfs_label) {
                        disk.status_detail = 'labeled';
                        disk.label_pool = status.pool_name;
                    }
                }
            });

            // Re-render disk buttons with updated status
            renderDiskButtons(pageData.all_disks, pageData.pool_devices);
        }

        // Unlock operation cards now that disks have been checked
        unlockOperationCards();

        // Transition modal to complete state
        if (modalData) {
            modalData.state = 'complete';
        }
    } catch (err) {
        console.error('Error checking disk usage:', err);
        // Transition modal to error state
        if (modalData) {
            modalData.errorMsg = 'Error checking disk usage: ' + (err.message || 'Unknown error');
            modalData.state = 'error';
        }
    }
}

