        html += '<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">';
        inUseDisksList.forEach(function(disk) {
            html += '<div class="disk-btn disk-btn-active px-3 py-2 text-xs font-mono rounded-lg border-2">';
            html += '<div class="font-semibold">' + escHtml(disk.name) + '</div>';
            html += '<div class="text-text-tertiary">' + escHtml(disk.size) + ' ' + escHtml(disk.type) + '</div>';
