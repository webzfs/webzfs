    // System disks
    if (systemDisksList.length > 0) {
        html += '<div><h3 class="text-sm font-semibold text-danger-400 mb-2">System Disks (' + systemDisksList.length + ')</h3>';
        html += '<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">';
        systemDisksList.forEach(function(disk) {
            html += '<div class="disk-btn disk-btn-system px-3 py-2 text-xs font-mono rounded-lg border-2">';
            html += '<div class="font-semibold">' + escHtml(disk.name) + '</div>';
