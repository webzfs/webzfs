{# HTMX fragment: Snapshot detail data sections #}

<!-- Cloned Snapshot Banner -->
{% if 'clones' in snapshot.properties and snapshot.properties.clones.value not in ['-', '', 'none'] %}
<div class="card-nested bg-purple-900/20 border-purple-800/50">
    <div class="flex items-start gap-3">
        <div class="flex-shrink-0 mt-0.5">
            <svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
            </svg>
        </div>
        <div class="flex-1">
            <div class="text-purple-400 font-semibold text-sm">Snapshot Has Been Cloned</div>
            <div class="text-text-secondary text-sm mt-1">
                {% set clone_list = snapshot.properties.clones.value.split(',') %}
                This snapshot has {{ clone_list|length }} clone{{ 's' if clone_list|length > 1 else '' }}:
            </div>
            <div class="mt-2 flex flex-wrap gap-2">
                {% for clone_name in clone_list %}
                {% set trimmed_clone = clone_name.strip() %}
                {% if trimmed_clone %}
                <a href="/zfs/datasets/{{ trimmed_clone }}"
                   class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-md bg-purple-900/30 border border-purple-700/50 text-purple-300 hover:text-purple-200 hover:bg-purple-900/50 transition-colors text-sm font-mono">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                    </svg>
                    {{ trimmed_clone }}
                </a>
                {% endif %}
                {% endfor %}
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Basic Information Grid -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- Basic Information -->
    <div class="card">
        <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
            <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
                <svg class="w-5 h-5 text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Basic Information
            </h2>
        </div>
        <div class="p-6">
            <dl class="space-y-3">
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Full Name:</dt>
                    <dd class="text-text-primary font-mono text-sm">{{ snapshot.name }}</dd>
                </div>
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Dataset:</dt>
                    <dd>
                        <a href="/zfs/datasets/{{ snapshot.dataset }}" class="text-primary-400 hover:text-primary-300 transition-colors">
                            {{ snapshot.dataset }}
                        </a>
                    </dd>
                </div>
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Snapshot Name:</dt>
                    <dd class="text-text-primary font-semibold">{{ snapshot.snapshot }}</dd>
                </div>
                {% if 'creation' in snapshot.properties %}
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Created:</dt>
                    <dd class="text-text-primary">{{ snapshot.properties.creation.value }}</dd>
                </div>
                {% endif %}
                {% if 'guid' in snapshot.properties %}
                <div class="flex justify-between py-2">
                    <dt class="text-text-tertiary">GUID:</dt>
                    <dd class="text-text-primary font-mono text-xs">{{ snapshot.properties.guid.value }}</dd>
                </div>
                {% endif %}
            </dl>
        </div>
    </div>

    <!-- Space Usage -->
    <div class="card">
        <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
            <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
                <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Space Usage
            </h2>
        </div>
        <div class="p-6">
            {% if space %}
            <dl class="space-y-3">
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Used:</dt>
                    <dd class="text-text-primary font-semibold">{{ space.used }}</dd>
                </div>
                <div class="flex justify-between py-2 border-b border-border-subtle">
                    <dt class="text-text-tertiary">Referenced:</dt>
                    <dd class="text-text-primary">{{ space.refer }}</dd>
                </div>
                <div class="flex justify-between py-2">
                    <dt class="text-text-tertiary">Logical Used:</dt>
                    <dd class="text-text-primary">{{ space.logicalused }}</dd>
                </div>
            </dl>
            {% else %}
            <p class="text-text-tertiary text-sm">Space information not available</p>
            {% endif %}
        </div>
    </div>
</div>

<!-- Snapshot Holds -->
<div class="card">
    <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
        <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
            <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
            Snapshot Holds
        </h2>
    </div>
    <div class="p-6">
        <p class="text-text-tertiary text-sm mb-4">Holds prevent snapshots from being destroyed until they are released.</p>
        {% if holds and holds|length > 0 %}
        <div class="space-y-2">
            {% for tag, timestamp in holds.items() %}
            <div class="flex justify-between items-center bg-bg-elevated-2 rounded-lg p-4 border border-border-subtle">
                <div>
                    <div class="text-text-primary font-semibold">{{ tag }}</div>
                    <div class="text-text-tertiary text-xs">Created: {{ timestamp }}</div>
                </div>
                <button type="button"
                        class="btn-danger text-sm"
                        onclick="showConfirm('confirm-release-{{ loop.index }}')">
                    Release Hold
                </button>
            </div>
            {% endfor %}
        </div>
        {% else %}
        <form method="post" action="/zfs/snapshots/{{ snapshot.name }}/hold" class="flex flex-col sm:flex-row gap-3 items-end">
            <div class="flex-1 w-full">
                <label for="tag" class="form-label">Hold Tag Name</label>
                <input type="text" 
                       id="tag" 
                       name="tag" 
                       required
                       placeholder="e.g., backup-hold"
                       class="form-input w-full">
            </div>
            <button type="submit" class="btn-primary inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                </svg>
                Place Hold
            </button>
        </form>
        {% endif %}
    </div>
</div>

<!-- Key Properties -->
<div class="card">
    <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
        <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
            Key Properties
        </h2>
    </div>
    <div class="p-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            {% if 'type' in snapshot.properties %}
            <div class="flex justify-between py-2 border-b border-border-subtle">
                <dt class="text-text-tertiary">Type:</dt>
                <dd class="text-text-primary">{{ snapshot.properties.type.value }}</dd>
            </div>
            {% endif %}
            {% if 'clones' in snapshot.properties %}
            <div class="flex justify-between py-2 border-b border-border-subtle">
                <dt class="text-text-tertiary">Clones:</dt>
                <dd>
                    {% if snapshot.properties.clones.value not in ['-', '', 'none'] %}
                    <div class="flex flex-wrap gap-1.5">
                        {% for clone_name in snapshot.properties.clones.value.split(',') %}
                        {% set trimmed_clone = clone_name.strip() %}
                        {% if trimmed_clone %}
                        <a href="/zfs/datasets/{{ trimmed_clone }}" class="text-purple-400 hover:text-purple-300 transition-colors font-mono text-sm">{{ trimmed_clone }}</a>{% if not loop.last %}<span class="text-text-tertiary">,</span>{% endif %}
                        {% endif %}
                        {% endfor %}
                    </div>
                    {% else %}
                    <span class="text-text-tertiary">None</span>
                    {% endif %}
                </dd>
            </div>
            {% endif %}
            {% if 'defer_destroy' in snapshot.properties %}
            <div class="flex justify-between py-2 border-b border-border-subtle">
                <dt class="text-text-tertiary">Defer Destroy:</dt>
                <dd class="text-text-primary">{{ snapshot.properties.defer_destroy.value }}</dd>
            </div>
            {% endif %}
            {% if 'userrefs' in snapshot.properties %}
            <div class="flex justify-between py-2 border-b border-border-subtle">
                <dt class="text-text-tertiary">User References:</dt>
                <dd class="text-text-primary">{{ snapshot.properties.userrefs.value }}</dd>
            </div>
            {% endif %}
        </div>
    </div>
</div>

<!-- Actions -->
<div class="card">
    <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
        <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
            <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
            Snapshot Actions
        </h2>
    </div>
    <div class="p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-4">
            <a href="/zfs/snapshots/{{ snapshot.name }}/clone/form" class="btn-success flex items-center justify-center gap-2 py-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
                </svg>
                Clone to Dataset
            </a>
            <a href="/zfs/snapshots/{{ snapshot.name }}/rollback/confirm" class="btn-warning flex items-center justify-center gap-2 py-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"></path>
                </svg>
                Rollback Dataset
            </a>
            <a href="/zfs/snapshots/{{ snapshot.name }}/rename/form" class="btn-primary flex items-center justify-center gap-2 py-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Rename Snapshot
            </a>
            <a href="/zfs/snapshots/diff/form?snapshot1={{ snapshot.name }}" class="btn-info flex items-center justify-center gap-2 py-3">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                Compare Changes
            </a>
            {% if has_bookmark %}
            <form method="post" action="/zfs/snapshots/bookmarks/destroy" class="flex" id="form-remove-bookmark">
                <input type="hidden" name="bookmark_name" value="{{ bookmark_name }}">
                <button type="button" class="btn-secondary flex items-center justify-center gap-2 py-3 w-full"
                        onclick="showConfirm('modal-remove-bookmark')">
                    <svg class="w-4 h-4 text-purple-400" fill="currentColor" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                    </svg>
                    Remove Bookmark
                </button>
            </form>
            {% else %}
            <form method="post" action="/zfs/snapshots/{{ snapshot.name }}/bookmark" class="flex">
                <button type="submit" class="btn-secondary flex items-center justify-center gap-2 py-3 w-full">
                    <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/>
                    </svg>
                    Create Bookmark
                </button>
            </form>
            {% endif %}
        </div>
        <div>
            <a href="/zfs/snapshots/{{ snapshot.name }}/destroy/confirm" class="btn-danger inline-flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                </svg>
                Destroy Snapshot
            </a>
        </div>
        <div class="card-nested mt-4">
            <p class="text-xs text-text-tertiary inline-flex items-start gap-2">
                <svg class="w-4 h-4 text-warning-400 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                </svg>
                <span>
                    Warning: Rollback and destroy operations are destructive and cannot be undone. 
                    Rollback will destroy any data created after this snapshot.
                </span>
            </p>
        </div>
    </div>
</div>

<!-- All Properties -->
<div class="card">
    <div class="p-4 bg-bg-elevated-2 border-b border-border-subtle">
        <h2 class="text-xl font-semibold text-text-primary inline-flex items-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"></path>
            </svg>
            All Properties
        </h2>
    </div>
    <div class="overflow-x-auto">
        <table class="min-w-full">
            <thead class="bg-bg-elevated-2">
                <tr>
                    <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Property</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Value</th>
                    <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Source</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-border-subtle">
                {% for prop_name, prop_data in snapshot.properties.items() %}
                <tr class="hover:bg-bg-elevated-2 transition-colors">
                    <td class="px-6 py-4 text-sm font-mono text-text-primary">{{ prop_name }}</td>
                    <td class="px-6 py-4 text-sm text-text-primary">{{ prop_data.value }}</td>
                    <td class="px-6 py-4 text-sm text-text-tertiary">{{ prop_data.source }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Confirmation Modals for Hold Release -->
{% if holds and holds|length > 0 %}
    {% for tag, timestamp in holds.items() %}
    {% set modal_id = 'confirm-release-' ~ loop.index %}
    {% set modal_title = 'Release Snapshot Hold' %}
    {% set modal_message = 'Release hold "' ~ tag ~ '" from snapshot ' ~ snapshot.name ~ '? This will allow the snapshot to be destroyed.' %}
    {% set confirm_text = 'Release Hold' %}
    {% set confirm_class = 'danger' %}
    {% set action_url = '/zfs/snapshots/' ~ snapshot.name ~ '/release' %}
    {% set method = 'post' %}
    {% include 'partials/confirm.jinja' %}
    {% endfor %}
{% endif %}

<!-- Bookmark Remove Confirmation Modal -->
{% if has_bookmark %}
    {% set id = 'modal-remove-bookmark' %}
    {% set title = 'Remove Bookmark' %}
    {% set message = 'Remove bookmark "' ~ bookmark_name ~ '"? This will remove the bookmark reference but will not affect the snapshot.' %}
    {% set confirm_text = 'Remove' %}
    {% set confirm_class = 'danger' %}
    {% set confirm_action = 'document.getElementById("form-remove-bookmark").submit()' %}
    {% include 'partials/confirm.jinja' %}
{% endif %}
