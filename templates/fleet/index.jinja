{% extends "layout_main.jinja" %}

{% block title %}Fleet View - {{ settings.CAPTION }}{% endblock %}

{% block content %}
<style>
  @keyframes pulse-border-danger {
    0%, 100% {
      border-color: rgb(239 68 68);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7),
                  0 0 0 3px rgba(239, 68, 68, 0.4),
                  0 0 0 6px rgba(239, 68, 68, 0.1);
    }
    50% {
      border-color: rgba(239, 68, 68, 0.5);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3),
                  0 0 0 3px rgba(239, 68, 68, 0.2),
                  0 0 0 6px rgba(239, 68, 68, 0.05);
    }
  }
  @keyframes pulse-border-warning {
    0%, 100% {
      border-color: rgb(234 179 8);
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7),
                  0 0 0 3px rgba(234, 179, 8, 0.4),
                  0 0 0 6px rgba(234, 179, 8, 0.1);
    }
    50% {
      border-color: rgba(234, 179, 8, 0.5);
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.3),
                  0 0 0 3px rgba(234, 179, 8, 0.2),
                  0 0 0 6px rgba(234, 179, 8, 0.05);
    }
  }
  .pulse-border-danger {
    animation: pulse-border-danger 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    border: 4px solid rgb(239 68 68);
  }
  .pulse-border-warning {
    animation: pulse-border-warning 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    border: 4px solid rgb(234 179 8);
  }
</style>
<div class="container-page py-8">
  
  {# Page Header #}
  <div class="mb-6">
    <h1 class="text-3xl font-bold text-text-primary mb-2 flex items-center">
      <svg class="w-8 h-8 mr-3 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
      </svg>
      Fleet View
    </h1>
  </div>

  {# Read-Only Banner #}
  <div class="mb-6 p-4 bg-purple-500/10 border border-purple-500/30 rounded-lg flex items-start">
    <svg class="w-6 h-6 text-purple-400 mr-3 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
    </svg>
    <div>
      <h3 class="font-semibold text-purple-400 mb-1">Read-Only Monitoring View</h3>
      <p class="text-text-secondary text-sm">
        This is a fleet-wide monitoring view. All management actions must be performed on each respective server directly.
        This interface only displays pool status information from remote servers via SSH.
      </p>
      <p class="text-text-secondary text-sm mt-2">
        <a href="https://github.com/webzfs/webzfs-fleet" target="_blank" class="text-purple-400 hover:text-purple-300 underline">webzfs-fleet</a> 
        is an in-development version that allows for full control of all your ZFS servers.
      </p>
    </div>
  </div>

  {# Success/Error Messages #}
  {% if request.query_params.get('success') %}
    {% include "partials/success.jinja" with context %}
  {% endif %}
  
  {% if request.query_params.get('error') %}
    {% include "partials/error.jinja" with context %}
  {% endif %}

  {# Action Buttons and Auto-Refresh #}
  <div x-data="{
    enabled: localStorage.getItem('fleetAutoRefresh') !== 'false',
    interval: 600,
    remaining: 600,
    timer: null,
    init() {
      if (this.enabled) { this.start(); }
    },
    start() {
      this.remaining = this.interval;
      this.timer = setInterval(() => {
        this.remaining--;
        if (this.remaining <= 0) {
          this.stop();
          let form = document.getElementById('fleet-refresh-form');
          if (form) { form.submit(); }
        }
      }, 1000);
    },
    stop() {
      if (this.timer) { clearInterval(this.timer); this.timer = null; }
    },
    toggle() {
      this.enabled = !this.enabled;
      localStorage.setItem('fleetAutoRefresh', this.enabled);
      if (this.enabled) { this.start(); } else { this.stop(); }
    },
    formatTime() {
      let m = Math.floor(this.remaining / 60);
      let s = this.remaining % 60;
      return m + ':' + (s < 10 ? '0' : '') + s;
    }
  }" class="mb-6">
    <div class="flex flex-wrap items-center gap-3">
      <a href="/fleet/servers/add" class="btn-primary inline-flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Add Server
      </a>
      
      {% if servers %}
      <form id="fleet-refresh-form" action="/fleet/refresh" method="post" class="inline">
        <button type="submit" class="btn-success inline-flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          Refresh All Servers
        </button>
      </form>
      
      <a href="/fleet/servers/remove" class="btn-secondary inline-flex items-center">
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
        </svg>
        Manage Servers
      </a>

      {# Auto-Refresh Toggle #}
      <div class="ml-auto flex items-center gap-3">
        <button @click="toggle()" class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors"
                :class="enabled ? 'bg-success-500/15 text-success-400 border border-success-500/30' : 'bg-bg-elevated-2 text-text-tertiary border border-border-default hover:text-text-secondary'">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
          </svg>
          <span x-text="enabled ? 'Auto-Refresh On' : 'Auto-Refresh Off'"></span>
        </button>
        <span x-show="enabled" x-cloak class="text-xs text-text-tertiary font-mono" x-text="'Next: ' + formatTime()"></span>
      </div>
      {% endif %}
    </div>
  </div>

  {# Server List

     Each card is rendered from `partials/server_card.jinja` with
     `auto_refresh=true`, which embeds an `hx-trigger="load delay:Nms"`
     directive on the card wrapper. After the page paints, HTMX fires
     one request per card (staggered by `loop_index * 250ms` so they
     don't all hit the SSH backend at the same time) to
     `/fleet/servers/{id}/card`, which runs `fetch_server_pools` and
     returns a fresh card. The card is swapped in via `outerHTML` with
     `auto_refresh=false`, so the refresh does not loop. #}
  {% if servers %}
    <div class="space-y-3">
      {% for server in servers %}
        {% with auto_refresh=True, loop_index=loop.index0, refresh_error=None %}
          {% include "fleet/partials/server_card.jinja" %}
        {% endwith %}
      {% endfor %}
    </div>
  {% else %}
    {# Empty State #}
    <div class="card">
      <div class="card-body text-center py-16">
        <svg class="w-16 h-16 mx-auto mb-6 text-purple-400/30" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01"></path>
        </svg>
        <h3 class="text-xl font-semibold text-text-primary mb-2">No Servers Configured</h3>
        <p class="text-text-secondary mb-6 max-w-md mx-auto">
          Get started by adding your first remote server to monitor its ZFS pools.
          You'll need SSH credentials to connect.
        </p>
        <a href="/fleet/servers/add" class="btn-primary inline-flex items-center">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
          Add Your First Server
        </a>
      </div>
    </div>
  {% endif %}

</div>

{# ===================================================================
   Dataset Space Usage Modal (fleet-only).
   Eye buttons in the pool table open this modal which fetches the
   dataset hierarchy from the remote server and renders an icicle/
   flamegraph layout. Pool detail page on this same WebZFS instance
   uses an inline visualizer; the renderer JS is duplicated here so
   the two pages stay independent.
=================================================================== #}
<div id="fleet-viz-modal"
     class="fixed inset-0 z-50 hidden items-center justify-center bg-black/70 backdrop-blur-sm p-4"
     style="display:none;">
  <div class="bg-bg-elevated-1 border border-border-subtle rounded-lg shadow-2xl w-full max-w-6xl max-h-[90vh] flex flex-col">
    <div class="flex items-center justify-between px-5 py-3 border-b border-border-subtle">
      <div class="min-w-0">
        <h2 class="text-lg font-semibold text-text-primary truncate flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
          </svg>
          <span id="fleet-viz-title">Dataset Space Usage</span>
        </h2>
        <p id="fleet-viz-subtitle" class="text-xs text-text-tertiary font-mono mt-0.5"></p>
      </div>
      <div class="flex items-center gap-3">
        <label class="inline-flex items-center gap-2 text-text-secondary cursor-pointer select-none text-sm">
          <input type="checkbox" id="fleet-viz-show-snapshots" checked
                 class="form-checkbox h-4 w-4 rounded border-border-subtle bg-bg-elevated-2 text-primary-500 focus:ring-primary-500">
          <span>Show snapshot bands</span>
        </label>
        <label class="inline-flex items-center gap-2 text-text-secondary cursor-pointer select-none text-sm"
               title="Shrink the free-space block so dataset segments fill more of the row.">
          <input type="checkbox" id="fleet-viz-collapse-free"
                 class="form-checkbox h-4 w-4 rounded border-border-subtle bg-bg-elevated-2 text-primary-500 focus:ring-primary-500">
          <span>Collapse free space</span>
        </label>
        <button type="button" id="fleet-viz-back"
                class="btn-secondary text-sm inline-flex items-center gap-1 disabled:opacity-50 disabled:cursor-not-allowed"
                disabled>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          Back
        </button>
        <button type="button" id="fleet-viz-close"
                class="text-text-tertiary hover:text-text-primary transition-colors p-1 rounded"
                aria-label="Close">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
    <div class="px-5 py-2 border-b border-border-subtle text-sm">
      <div id="fleet-viz-breadcrumb" class="text-text-secondary"></div>
    </div>
    <div class="flex-1 overflow-auto p-5">
      <div id="fleet-viz-container"
           class="relative w-full bg-bg-base border border-border-subtle rounded-lg overflow-hidden">
        <div id="fleet-viz-loading" class="flex items-center justify-center text-text-tertiary text-sm py-12">
          Loading dataset usage...
        </div>
        <svg id="fleet-viz-svg" class="block w-full" style="display:none;" preserveAspectRatio="none"></svg>
      </div>
      <div id="fleet-viz-tooltip"
           class="hidden absolute z-30 bg-bg-elevated-2 border border-border-subtle rounded-lg shadow-lg px-3 py-2 text-xs text-text-primary pointer-events-none"
           style="position: fixed; max-width: 320px;">
      </div>
      <p class="text-xs text-text-tertiary mt-3">

        Each row is one level of dataset depth. Segment width is proportional to space used relative to the parent.
        Click a segment to drill in. The visualization shows up to four levels.
      </p>
    </div>
  </div>
</div>




<script src="/static/js/space_visualizer.js"></script>
<script>
(function() {
    "use strict";

    var modal = document.getElementById("fleet-viz-modal");
    if (!modal) return;

    var titleEl = document.getElementById("fleet-viz-title");
    var subtitleEl = document.getElementById("fleet-viz-subtitle");
    var closeBtn = document.getElementById("fleet-viz-close");
    var container = document.getElementById("fleet-viz-container");
    var svg = document.getElementById("fleet-viz-svg");
    var loadingEl = document.getElementById("fleet-viz-loading");
    var tooltipEl = document.getElementById("fleet-viz-tooltip");
    var breadcrumbEl = document.getElementById("fleet-viz-breadcrumb");
    var backBtn = document.getElementById("fleet-viz-back");
    var snapshotToggle = document.getElementById("fleet-viz-show-snapshots");
    var collapseFreeToggle = document.getElementById("fleet-viz-collapse-free");

    var currentViz = null;
    var currentServerId = null;
    var currentPool = null;

    // The page body uses hx-boost="true", so navigations into /fleet/
    // happen via an htmx XHR + body-swap rather than a real page load.
    // When htmx evaluates the swapped scripts in order, it creates a new
    // <script src="space_visualizer.js"> element and appends it (which
    // loads asynchronously) and then immediately creates and appends
    // this inline <script> element which executes synchronously. The
    // result is that on a boosted navigation window.WebzfsSpaceVisualizer
    // is frequently still undefined when this IIFE runs. Previously we
    // bailed out via `if (!window.WebzfsSpaceVisualizer) return;` which
    // meant the document-level click handler for the visualize buttons
    // never got attached, and clicks landed on dead space until some
    // unrelated body swap re-ran this script with the global defined.
    //
    // Fix: always wire up the click / close / Escape listeners, and
    // wait for the external library to finish loading inside the
    // click handler instead. The hover highlight comes from CSS so it
    // is unaffected; only the click path needed to be made tolerant
    // of the external script still being in flight.
    function whenVisualizerReady(callback) {
        if (window.WebzfsSpaceVisualizer) {
            callback();
            return;
        }
        var attempts = 0;
        var timer = setInterval(function() {
            attempts += 1;
            if (window.WebzfsSpaceVisualizer) {
                clearInterval(timer);
                callback();
            } else if (attempts > 60) {
                // ~3 seconds is plenty for a cached static asset.
                clearInterval(timer);
                if (loadingEl) {
                    loadingEl.textContent = "Failed to load visualizer script.";
                }
                console.error(
                    "space_visualizer.js did not load in time; "
                    + "the dataset visualizer cannot open."
                );
            }
        }, 50);
    }


    function openModal() {
        modal.style.display = "flex";
        modal.classList.remove("hidden");
        modal.classList.add("flex");
    }

    function closeModal() {
        modal.style.display = "none";
        modal.classList.add("hidden");
        modal.classList.remove("flex");
        if (tooltipEl) tooltipEl.classList.add("hidden");
        if (currentViz && currentViz.destroy) {
            currentViz.destroy();
        }
        currentViz = null;
        currentServerId = null;
        currentPool = null;
    }

    closeBtn.addEventListener("click", closeModal);
    modal.addEventListener("click", function(ev) {
        if (ev.target === modal) closeModal();
    });
    document.addEventListener("keydown", function(ev) {
        if (ev.key === "Escape" && modal.style.display === "flex") {
            closeModal();
        }
    });

    function buildFetcher(serverId, poolName) {
        return function() {
            var url = "/fleet/servers/" + encodeURIComponent(serverId)
                + "/pools/" + encodeURIComponent(poolName) + "/space-tree";
            return fetch(url, { credentials: "same-origin" })
                .then(function(resp) { return resp.json(); })
                .then(function(data) {
                    if (!data || !data.success) {
                        throw new Error(data && data.error ? data.error : "Request failed");
                    }
                    return data.tree;
                });
        };
    }

    function refreshServer(serverId) {
        // Force the fleet service to re-establish the SSH session and
        // re-fetch the pool list for this server before we ask for the
        // space tree. Without this, a stale SSH client occasionally
        // makes the first space-tree call fail silently and the user
        // has to click the per-server "Refresh" button before the
        // visualize button does anything. The refresh endpoint redirects
        // to /fleet/ on success, but we only care that the server-side
        // state is freshened, so we ignore the response body.
        return fetch("/fleet/servers/" + encodeURIComponent(serverId) + "/refresh", {
            method: "POST",
            credentials: "same-origin",
            redirect: "manual"
        }).catch(function() {
            // A failed refresh should not block the visualizer attempt;
            // the space-tree request will surface its own error if the
            // server is genuinely unreachable.
            return null;
        });
    }

    function openForPool(serverId, serverName, poolName) {
        currentServerId = serverId;
        currentPool = poolName;
        titleEl.textContent = "Dataset Space Usage: " + poolName;
        subtitleEl.textContent = serverName + " (" + serverId.substring(0, 8) + ")";
        openModal();

        if (loadingEl) {
            loadingEl.textContent = "Refreshing server connection...";
            loadingEl.style.display = "";
        }
        svg.style.display = "none";

        // Wait for the external visualizer script to finish loading
        // before instantiating it. On a boosted nav into /fleet/ this
        // typically resolves on the very first tick because the asset
        // is cached.
        whenVisualizerReady(function() {
            if (currentServerId !== serverId || currentPool !== poolName) {
                // User closed or switched pools while we were waiting
                // for the script to load.
                return;
            }
            // Recreate the visualizer each time so view stack resets.
            if (currentViz && currentViz.destroy) {
                currentViz.destroy();
            }
            currentViz = window.WebzfsSpaceVisualizer.create({
                container: container,
                svg: svg,
                loadingEl: loadingEl,
                tooltip: tooltipEl,
                breadcrumb: breadcrumbEl,
                backButton: backBtn,
                snapshotToggle: snapshotToggle,
                collapseFreeToggle: collapseFreeToggle,
                maxDepth: 4,
                fetchTree: buildFetcher(serverId, poolName)
            });

            // Auto-refresh the server first so the SSH session is
            // healthy and the pool list is current before the
            // visualizer fetches the dataset tree.
            refreshServer(serverId).then(function() {
                if (currentServerId !== serverId || currentPool !== poolName) {
                    // User closed or switched pools while the refresh
                    // was in flight; do not stomp the new state.
                    return;
                }
                if (currentViz) {
                    currentViz.load();
                }
            });
        });
    }


    document.addEventListener("click", function(ev) {
        var btn = ev.target.closest("[data-fleet-viz-pool]");
        if (!btn) return;
        ev.preventDefault();
        openForPool(
            btn.getAttribute("data-fleet-viz-server-id"),
            btn.getAttribute("data-fleet-viz-server-name") || "",
            btn.getAttribute("data-fleet-viz-pool")
        );
    });
})();
</script>
{% endblock %}
