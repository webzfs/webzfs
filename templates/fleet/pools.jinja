{% extends "layout_main.jinja" %}

{% block title %}Fleet Pools - {{ settings.CAPTION }}{% endblock %}

{% block content %}
<style>
  @keyframes pulse-border-danger {
    0%, 100% {
      border-color: rgb(239 68 68);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7),
                  0 0 0 3px rgba(239, 68, 68, 0.4),
                  0 0 0 6px rgba(239, 68, 68, 0.1);
    }
    50% {
      border-color: rgba(239, 68, 68, 0.5);
      box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3),
                  0 0 0 3px rgba(239, 68, 68, 0.2),
                  0 0 0 6px rgba(239, 68, 68, 0.05);
    }
  }
  @keyframes pulse-border-warning {
    0%, 100% {
      border-color: rgb(234 179 8);
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7),
                  0 0 0 3px rgba(234, 179, 8, 0.4),
                  0 0 0 6px rgba(234, 179, 8, 0.1);
    }
    50% {
      border-color: rgba(234, 179, 8, 0.5);
      box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.3),
                  0 0 0 3px rgba(234, 179, 8, 0.2),
                  0 0 0 6px rgba(234, 179, 8, 0.05);
    }
  }
  .pulse-border-danger {
    animation: pulse-border-danger 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    border: 4px solid rgb(239 68 68);
  }
  .pulse-border-warning {
    animation: pulse-border-warning 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    border: 4px solid rgb(234 179 8);
  }
</style>
<div class="container-page py-8">

  {# ZFS Pools Card - matches dashboard style #}
  <div class="card animate-fade-in">
    <div class="card-body">
      <div class="flex items-center gap-3 mb-4">
        <div class="p-2 bg-purple-500/10 border border-purple-500/20 rounded-lg">
          <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
          </svg>
        </div>
        <h2 class="text-lg font-semibold text-text-primary">ZFS Pools</h2>
        <button type="button"
                class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                hx-get="/fleet/pools/data"
                hx-target="#fleet-pools-content"
                hx-swap="innerHTML"
                hx-indicator="#fleet-pools-spinner"
                title="Refresh pool information">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
        </button>
        <svg id="fleet-pools-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      </div>
      {# Async load: all fleet pools #}
      <div id="fleet-pools-content"
           hx-get="/fleet/pools/data"
           hx-trigger="load"
           hx-swap="innerHTML">
        <div class="flex items-center justify-center py-8">
          <svg class="w-6 h-6 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span class="ml-2 text-sm text-text-tertiary">Loading pool information from all servers...</span>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}
