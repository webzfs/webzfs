{% extends "layout.jinja" %}

{% set active_page = 'dashboard' %}

{% block content %}
    <style>
        /* Pool health pulse animations */
        @keyframes pulse-border-danger {
            0%, 100% {
                border-color: rgb(239 68 68);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7),
                            0 0 0 3px rgba(239, 68, 68, 0.4),
                            0 0 0 6px rgba(239, 68, 68, 0.1);
            }
            50% {
                border-color: rgba(239, 68, 68, 0.5);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3),
                            0 0 0 3px rgba(239, 68, 68, 0.2),
                            0 0 0 6px rgba(239, 68, 68, 0.05);
            }
        }
        @keyframes pulse-border-warning {
            0%, 100% {
                border-color: rgb(234 179 8);
                box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7),
                            0 0 0 3px rgba(234, 179, 8, 0.4),
                            0 0 0 6px rgba(234, 179, 8, 0.1);
            }
            50% {
                border-color: rgba(234, 179, 8, 0.5);
                box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.3),
                            0 0 0 3px rgba(234, 179, 8, 0.2),
                            0 0 0 6px rgba(234, 179, 8, 0.05);
            }
        }
        .pulse-border-danger {
            animation: pulse-border-danger 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            border: 4px solid rgb(239 68 68);
        }
        .pulse-border-warning {
            animation: pulse-border-warning 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            border: 4px solid rgb(234 179 8);
        }
    </style>

    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-text-primary">System Dashboard</h1>
                <p class="text-text-secondary mt-1">Holistic overview of system resources and ZFS status</p>
            </div>
        </div>

        <!-- ================================================================
             ROW 1: System Info | Memory + Load | CPU Time  (3 columns)
             ================================================================ -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Column 1: System Specs + Uptime -->
            <div class="card animate-fade-in">
                <div class="card-body">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="p-2 bg-primary-500/10 border border-primary-500/20 rounded-lg">
                            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="text-lg font-semibold text-text-primary">System Information</h2>
                    </div>

                    {% if specs %}
                    <table class="w-full text-sm">
                        <tbody class="divide-y divide-border-subtle">
                            <tr><td class="py-1.5 text-text-secondary w-28">Hostname</td><td class="py-1.5 text-text-primary font-medium">{{ specs.hostname }}</td></tr>
                            <tr><td class="py-1.5 text-text-secondary">CPU</td><td class="py-1.5 text-text-primary text-xs">{{ specs.cpu_model }}</td></tr>
                            <tr><td class="py-1.5 text-text-secondary">Cores</td><td class="py-1.5 text-text-primary">{{ specs.cpu_count_physical or '?' }} physical / {{ specs.cpu_count }} logical</td></tr>
                            <tr><td class="py-1.5 text-text-secondary">Platform</td><td class="py-1.5 text-text-primary text-xs">{{ specs.platform }}</td></tr>
                            {% if specs.os_release %}
                            <tr><td class="py-1.5 text-text-secondary">Release</td><td class="py-1.5 text-text-primary text-xs">{{ specs.os_release }}</td></tr>
                            {% endif %}
                            {% if specs.zfs_version %}
                            {% if specs.zfs_version.get('module') %}
                            <tr><td class="py-1.5 text-text-secondary">ZFS Module</td><td class="py-1.5 text-text-primary text-xs">{{ specs.zfs_version.module }}</td></tr>
                            {% endif %}
                            {% if specs.zfs_version.get('userland') %}
                            <tr><td class="py-1.5 text-text-secondary">ZFS Userland</td><td class="py-1.5 text-text-primary text-xs">{{ specs.zfs_version.userland }}</td></tr>
                            {% endif %}
                            {% endif %}
                        </tbody>
                    </table>
                    {% endif %}

                    <!-- Uptime (updated via OOB every 60s) -->
                    <div id="dash-uptime" class="mt-3 pt-3 border-t border-border-subtle">
                        {% if realtime and realtime.uptime %}
                        <div class="flex items-center gap-2 text-sm">
                            <svg class="w-4 h-4 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span class="text-text-secondary">Uptime:</span>
                            <span class="text-text-primary font-semibold">{{ realtime.uptime.formatted }}</span>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <!-- Column 2: Memory Usage (top) + System Load (bottom) stacked -->
            <div class="space-y-6">
                <!-- Memory Usage (refreshes every 15s) -->
                <div class="card animate-fade-in" style="animation-delay: 0.1s;">
                    <div class="card-body">
                        <div class="flex items-center gap-3 mb-3">
