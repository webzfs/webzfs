{% extends "layout.jinja" %}

{% set active_page = 'dashboard' %}

{% block content %}
    <style>
        /* Pool health pulse animations */
        @keyframes pulse-border-danger {
            0%, 100% {
                border-color: rgb(239 68 68);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.7),
                            0 0 0 3px rgba(239, 68, 68, 0.4),
                            0 0 0 6px rgba(239, 68, 68, 0.1);
            }
            50% {
                border-color: rgba(239, 68, 68, 0.5);
                box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.3),
                            0 0 0 3px rgba(239, 68, 68, 0.2),
                            0 0 0 6px rgba(239, 68, 68, 0.05);
            }
        }
        @keyframes pulse-border-warning {
            0%, 100% {
                border-color: rgb(234 179 8);
                box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.7),
                            0 0 0 3px rgba(234, 179, 8, 0.4),
                            0 0 0 6px rgba(234, 179, 8, 0.1);
            }
            50% {
                border-color: rgba(234, 179, 8, 0.5);
                box-shadow: 0 0 0 0 rgba(234, 179, 8, 0.3),
                            0 0 0 3px rgba(234, 179, 8, 0.2),
                            0 0 0 6px rgba(234, 179, 8, 0.05);
            }
        }
        .pulse-border-danger {
            animation: pulse-border-danger 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            border: 4px solid rgb(239 68 68);
        }
        .pulse-border-warning {
            animation: pulse-border-warning 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
            border: 4px solid rgb(234 179 8);
        }
    </style>

    <div class="space-y-6">
        <!-- Page Header -->
        <div class="flex items-center justify-between">
            <h1 class="text-3xl font-bold text-text-primary">System Dashboard</h1>
        </div>

        <!-- ================================================================
             ROW 1: System Info | Memory Usage | System Load  (3 columns)
             ================================================================ -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

            <!-- Column 1: System Specs + Uptime -->
            <div class="card animate-fade-in">
                <div class="card-body">
                    <div class="flex items-center gap-3 mb-4">
                        <div class="p-2 bg-primary-500/10 border border-primary-500/20 rounded-lg">
                            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                        </div>
                        <h2 class="text-lg font-semibold text-text-primary">System Information</h2>
                    </div>

                    <!-- Async load: system info -->
                    <div hx-get="/system-info-data"
                         hx-trigger="load"
                         hx-swap="innerHTML">
                        <div class="flex items-center justify-center py-8">
                            <svg class="w-6 h-6 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span class="ml-2 text-sm text-text-tertiary">Loading system info...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Column 2: Memory Usage -->
            <div class="card animate-fade-in" style="animation-delay: 0.1s;">
                <div class="card-body">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="p-2 bg-success-500/10 border border-success-500/20 rounded-lg">
                            <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/>
                            </svg>
                        </div>
                        <h2 class="text-lg font-semibold text-text-primary">Memory Usage</h2>
                        <button type="button"
                                class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                                hx-get="/memory-refresh"
                                hx-target="#memory-content"
                                hx-swap="innerHTML"
                                hx-indicator="#memory-spinner"
                                title="Refresh memory information">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                        </button>
                        <svg id="memory-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                    <!-- Async load: memory info -->
                    <div id="memory-content"
                         hx-get="/memory-data"
                         hx-trigger="load"
                         hx-swap="innerHTML">
                        <div class="flex items-center justify-center py-8">
                            <svg class="w-5 h-5 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span class="ml-2 text-sm text-text-tertiary">Loading memory info...</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Column 3: System Load -->
            <div class="card animate-fade-in" style="animation-delay: 0.15s;">
                <div class="card-body">
                    <div class="flex items-center gap-3 mb-3">
                        <div class="p-2 bg-info-500/10 border border-info-500/20 rounded-lg">
                            <svg class="w-5 h-5 text-info-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                            </svg>
                        </div>
                        <h2 class="text-lg font-semibold text-text-primary">System Load</h2>
                        <button type="button"
                                class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                                hx-get="/system-load-refresh"
                                hx-target="#system-load-content"
                                hx-swap="innerHTML"
                                hx-indicator="#system-load-spinner"
                                title="Refresh system load">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                            </svg>
                        </button>
                        <svg id="system-load-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </div>
                    <!-- Async load: system load -->
                    <div id="system-load-content"
                         hx-get="/system-load-data"
                         hx-trigger="load"
                         hx-swap="innerHTML">
                        <div class="flex items-center justify-center py-8">
                            <svg class="w-5 h-5 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span class="ml-2 text-sm text-text-tertiary">Loading system load...</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================================================================
             ROW 3: ZFS Pool Info (full width)
             ================================================================ -->
        <div class="card animate-fade-in" style="animation-delay: 0.4s;">
            <div class="card-body">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 bg-purple-500/10 border border-purple-500/20 rounded-lg">
                        <svg class="w-5 h-5 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4"/>
                        </svg>
                    </div>
                    <h2 class="text-lg font-semibold text-text-primary">ZFS Pools</h2>
                    <button type="button"
                            class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                            hx-get="/zfs-pools-refresh"
                            hx-target="#zfs-pools-content"
                            hx-swap="innerHTML"
                            hx-indicator="#zfs-pools-spinner"
                            title="Refresh pool information">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </button>
                    <svg id="zfs-pools-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
                <!-- Async load: ZFS pools -->
                <div id="zfs-pools-content"
                     hx-get="/zfs-pools-refresh"
                     hx-trigger="load"
                     hx-swap="innerHTML">
                    <div class="flex items-center justify-center py-8">
                        <svg class="w-6 h-6 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span class="ml-2 text-sm text-text-tertiary">Loading pool information...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================================================================
             ROW 4: ARC Statistics Summary
             ================================================================ -->
        <div class="card animate-fade-in" style="animation-delay: 0.5s;">
            <div class="card-body">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 bg-success-500/10 border border-success-500/20 rounded-lg">
                        <svg class="w-5 h-5 text-success-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>
                        </svg>
                    </div>
                    <h2 class="text-lg font-semibold text-text-primary">ARC Statistics</h2>
                    <a href="/zfs/observability/arc-summary" class="text-xs text-primary-400 hover:text-primary-300 transition-colors">Full ARC Stats</a>
                    <button type="button"
                            class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                            hx-get="/arc-stats-refresh"
                            hx-target="#arc-stats-content"
                            hx-swap="innerHTML"
                            hx-indicator="#arc-stats-spinner"
                            title="Refresh ARC statistics">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </button>
                    <svg id="arc-stats-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
                <!-- Async load: ARC stats (also refreshes every 5 min) -->
                <div id="arc-stats-content"
                     hx-get="/arc-stats-refresh"
                     hx-trigger="load, every 300s"
                     hx-swap="innerHTML">
                    <div class="flex items-center justify-center py-8">
                        <svg class="w-6 h-6 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span class="ml-2 text-sm text-text-tertiary">Loading ARC statistics...</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- ================================================================
             ROW 5: Scrub Status
             ================================================================ -->
        <div class="card animate-fade-in" style="animation-delay: 0.6s;">
            <div class="card-body">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 bg-warning-500/10 border border-warning-500/20 rounded-lg">
                        <svg class="w-5 h-5 text-warning-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                        </svg>
                    </div>
                    <h2 class="text-lg font-semibold text-text-primary">Scrub Status</h2>
                    <button type="button"
                            class="ml-auto p-1.5 rounded-lg hover:bg-bg-elevated-3 text-text-secondary hover:text-text-primary transition-colors"
                            hx-get="/scrub-status-refresh"
                            hx-target="#scrub-status-content"
                            hx-swap="innerHTML"
                            hx-indicator="#scrub-spinner"
                            title="Refresh scrub status">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
                        </svg>
                    </button>
                    <svg id="scrub-spinner" class="w-4 h-4 text-text-tertiary htmx-indicator animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                </div>
                <!-- Async load: scrub status (also refreshes every 5 min) -->
                <div id="scrub-status-content"
                     hx-get="/scrub-status-refresh"
                     hx-trigger="load, every 300s"
                     hx-swap="innerHTML">
                    <div class="flex items-center justify-center py-8">
                        <svg class="w-6 h-6 text-text-tertiary animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                        <span class="ml-2 text-sm text-text-tertiary">Loading scrub status...</span>
                    </div>
                </div>
            </div>
        </div>

    </div>

    {# Memory refreshes every 15 seconds via OOB swap #}
    <div hx-get="/realtime-data" hx-trigger="every 15s" hx-swap="none"></div>

    {# System stats (uptime, tasks, load) refresh every 60 seconds via OOB swap #}
    <div hx-get="/system-stats-refresh" hx-trigger="every 60s" hx-swap="none"></div>
{% endblock %}
